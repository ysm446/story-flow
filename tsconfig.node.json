{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "electron/main/**/*.ts",
    "electron/preload/**/*.ts"
  ]
}
